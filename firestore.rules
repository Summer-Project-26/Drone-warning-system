rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /alerts/{alertId} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasAll([
          'id', 'category', 'description', 'latitude', 'longitude',
          'createdAt', 'expiresAt', 'confirmations', 'verified',
          'level', 'userId', 'emergencySound'
        ])
        && request.resource.data.id == alertId
        && request.resource.data.category is string
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.level in ['normal', 'verified', 'emergency'];

      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['confirmations', 'verified', 'level', 'emergencySound']);

      allow delete: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    match /feedback/{feedbackId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
  }
}